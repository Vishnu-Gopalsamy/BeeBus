<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor"
    android:fitsSystemWindows="true">

    <!-- Simple Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-Ticket"
            android:textColor="@color/textWhite"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_ticket_bus_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bus Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:id="@+id/tv_ticket_pnr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PNR: BEE123456"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_ticket_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chennai"
                            android:textStyle="bold"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tv_ticket_dep_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="21:00" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="24sp"
                        android:layout_marginHorizontal="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tv_ticket_dest"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coimbatore"
                            android:textStyle="bold"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tv_ticket_arr_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="05:30" />

                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_ticket_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fri, 05 Mar 2026"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginVertical="16dp" />

                <TextView
                    android:id="@+id/tv_ticket_seats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seats: 12, 13" />

                <TextView
                    android:id="@+id/tv_ticket_passengers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe, Jane Doe"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

    <Button
        android:id="@+id/btn_download_ticket"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Download Ticket"
        android:background="@drawable/button_primary"
        android:textColor="@color/textWhite" />

</LinearLayout>

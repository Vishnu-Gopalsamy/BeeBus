<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_history_bus_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bus Name"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/textPrimary" />

            <TextView
                android:id="@+id/tv_history_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmed"
                android:textColor="@color/successGreen"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/success_light_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_history_route"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chennai to Coimbatore"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="@color/textSecondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dividerColor"
            android:layout_marginVertical="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="@color/textSecondary"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_history_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="05 Mar 2026"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_history_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1200"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/colorPrimary" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
